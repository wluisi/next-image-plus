{
  "name": "next-image-plus",
  "version": "1.0.0",
  "description": "Primitive React components, built on top of the Next.js Image API, which adds support for picture and background images.",
  "author": "William Luisi",
  "keywords": [
    "nextjs",
    "next",
    "react",
    "responsive",
    "image",
    "images",
    "responsive images",
    "picture",
    "srcset",
    "performance",
    "web vitals",
    "cls",
    "fcp",
    "lcp",
    "component",
    "typescript"
  ],
  "license": "MIT",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c --watch",
    "lint": "TIMING=1 eslint src",
    "prebuild": "rm -rf dist",
    "prepare": "cp ../../README.md ./README.md",
    "test": "vitest run --reporter=verbose"
  },
  "devDependencies": {
    "@next-image-plus/eslint-config": "*",
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^18.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "jsdom": "^26.0.0",
    "rollup": "^4.40.1",
    "rollup-plugin-dts": "^6.2.1",
    "rollup-plugin-esbuild": "^6.2.1",
    "rollup-preserve-directives": "^1.1.3",
    "typescript": "^5.8.2",
    "vitest": "4.1.9"
  },
  "peerDependencies": {
    "react": "^19 || ^19.0.0-rc",
    "react-dom": "^19 || ^19.0.0-rc",
    "next": "^15"
  },
  "homepage": "https://www.next-image-plus.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/wluisi/next-image-plus"
  },
  "bugs": {
    "url": "https://github.com/wluisi/next-image-plus/issues"
  }
}
